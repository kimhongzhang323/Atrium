DATABASE_URL=postgres://app_user:...@host/db
DATABASE_ADMIN_URL=postgres://app_admin:...@host/db
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=no-reply@atrium.local
AUTH_TRUST_HOST=true

# Background jobs (Vercel Cron sends `Authorization: Bearer $CRON_SECRET`)
CRON_SECRET=

# Stage 5 — Google Drive governance (service-account-per-org) + e-signature provider
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
ESIGN_PROVIDER=dropbox_sign
ESIGN_API_KEY=
ESIGN_WEBHOOK_SECRET=
